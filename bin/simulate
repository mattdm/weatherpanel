# Layout constants (set at init time, after --scale is known).
_WIN_W    = 1280
_WIN_H    = 1024
_MATRIX_H = 640   # 32 rows × scale=20
_PANEL_H  = _WIN_H - _MATRIX_H   # 384px for the status panel

# Neopixel dot: small overlay in the top-right corner of the log area.
# Radius matches one matrix pixel at default scale=20 (dot_fraction 0.8 → 8px).
_DOT_R   = 8
_DOT_MAR = 6   # margin from panel edges

# Portal "Connect/Disconnect" button — top-right of the status panel.
# Only rendered when _portal_mode is True.
_BTN_W   = 155
_BTN_H   = 22
_BTN_MAR = 6

# Colors for the status panel chrome.
_PANEL_BG  = (15,  15,  15)
_SEP_COL   = (50,  50,  50)
_DIM_COL   = (90,  90,  90)
_TEXT_COL  = (185, 185, 185)
_BTN_COL        = (40,  80,  40)   # connected / nominal state
_BTN_DISC       = (80,  40,  40)   # disconnected / broken state
_BTN_TXT        = (200, 230, 200)
_BTN_DISABLED   = (40,  40,  40)   # grayed out — button not applicable in current state
_REBOOT_BTN_COL = (65,  30,  20)   # dark rust — distinct from _BTN_COL/_BTN_DISC

_pg_screen      = None              # pygame.Surface
_log_lines      = None              # deque[str] — captured stdout
_pg_font        = None              # pygame.font.Font for log text
_log_scroll     = 0                 # lines scrolled back from the bottom (0 = newest)
_current_frame  = [None]            # latest PIL Image from the scheduler thread
_restart_flag    = threading.Event() # set by watcher thread, consumed in main thread
_reboot_requested = threading.Event() # set by reboot button click, consumed in event loop
_portal_mode    = False             # True when running the configuration portal
_scheduler_wifi  = [False]          # tracks simulated WiFi state in non-portal mode
_sim_dns_broken  = [False]          # tracks simulated DNS break state
_sim_isp_broken  = [False]          # tracks simulated ISP break state
_worker_stdin    = None             # stdin pipe of the worker subprocess (set by main)
# Set True while portal.run() is executing so _refresh_and_save uses fast
# flat rendering — antialiased circles are not useful for a 1-bit monochrome
# display and take several seconds per frame in pure Python, which blocks
# the portal's event loop between every screen transition.
_portal_rendering_active = [False]


def _led_vivid(img):
    """Simulate the appearance of a bright RGB LED matrix panel.

    Three physical characteristics drive the transform:

    Gamma lift — LED matrices drive sub-pixels at high current and run
    BCM PWM at 6-bit depth.  The perceived brightness follows a power
    curve much shallower than sRGB gamma 2.2.  Gamma 0.45 here pulls
    mid-range values sharply upward: R=255, G=106 orange becomes
    R=255, G=175 — nearly yellow — purely from the gamma-lifted green
    channel.  Dark palette entries (comfort green 0x0a3c00, rain blue
    0x0000D0) similarly jump to vivid brightness.

    Color shifts — common green LED emitters peak around 520 nm (lime),
    not the sRGB primary at 549 nm; blue emitters are around 460 nm
    (deep cool blue).  After the gamma lift, a small per-channel blend
    nudges green toward lime (add 12 % red to green) and blue toward a
    colder hue (reduce green bleed in the blue channel).

    Saturation — narrow-spectrum emitters produce more vivid color than
    broad sRGB primaries.  A 2.5× saturation pass after the above
    widens the remaining color separation without wrecking neutrals,
    which are already near white from the gamma lift.
    """
    from PIL import ImageEnhance

    # --- Gamma lift (applied per-channel via PIL LUT) ---
    # out = round(255 * (in / 255) ** 0.45);  black stays black.
    _GAMMA = 0.45
    _lut = bytes(round(255 * (i / 255) ** _GAMMA) if i > 0 else 0 for i in range(256))
    img = img.point(_lut * 3)   # 768-entry table: one 256-block per R/G/B channel

    # --- Per-channel color-shift blend (chromatic pixels only) ---
    # LED green emitters peak around 520 nm (lime), not sRGB green at 549 nm.
    # LED blue emitters are around 460 nm — deep, with minimal green bleed.
    # Both shifts are scaled by the pixel's chroma (max - min channel value)
    # so near-neutral and white pixels are left untouched — without this gate
    # the saturation pass below would amplify tiny tints into strong yellow casts.
    r_ch, g_ch, b_ch = img.split()
    r_px = r_ch.tobytes()
    g_px = g_ch.tobytes()
    b_px = b_ch.tobytes()

    new_g = bytearray(len(g_px))
    new_b = bytearray(len(b_px))
    for i in range(len(g_px)):
        r, g, b = r_px[i], g_px[i], b_px[i]
        chroma = (max(r, g, b) - min(r, g, b)) / 255.0   # 0 = neutral, 1 = fully saturated
        new_g[i] = min(255, int(g + chroma * 0.18 * r))  # lime nudge: blend in 18 % of red → green
        new_b[i] = max(0,   int(b - chroma * 0.20 * g))  # blue purify: subtract 20 % of green from blue

    from PIL import Image
    g_ch = Image.frombytes("L", img.size, bytes(new_g))
    b_ch = Image.frombytes("L", img.size, bytes(new_b))
    img = Image.merge("RGB", (r_ch, g_ch, b_ch))

    # --- Saturation boost ---
    img = ImageEnhance.Color(img).enhance(2.5)

    return img


def _live_init():
    """Initialize the pygame window (launcher only)."""
    global _pg_screen, _log_lines, _pg_font

    # Suppress pygame's startup chatter before importing it.
    import warnings
    warnings.filterwarnings("ignore", category=UserWarning,      module="pygame.pkgdata")
    warnings.filterwarnings("ignore", category=DeprecationWarning, module="pkg_resources")
    warnings.filterwarnings("ignore", category=DeprecationWarning, module="pygame")
    os.environ["PYGAME_HIDE_SUPPORT_PROMPT"] = "1"
    os.environ.setdefault("SDL_VIDEODRIVER", "wayland")

    import pygame

    # Redirect stderr at the fd level around pygame.init() to swallow native
    # library noise such as the Gtk "Failed to load module" message.
    _stderr_fd = os.dup(2)
    with open(os.devnull, "w") as _null:
        os.dup2(_null.fileno(), 2)
        try:
            pygame.init()
        finally:
            os.dup2(_stderr_fd, 2)
            os.close(_stderr_fd)
    pygame.display.set_caption("weatherpanel")
    _pg_screen = pygame.display.set_mode((_WIN_W, _WIN_H))

    _pg_font = pygame.font.SysFont("monospace", 13)
    pygame.key.set_repeat(300, 50)

    # Log lines are populated by the worker-stderr reader thread.
    _log_lines = collections.deque(maxlen=300)

    _live_draw_panel()
    pygame.display.flip()


def _start_worker_proc():
    """Spawn a worker subprocess that runs the scheduler and pipes frames to us."""
    # Pass through all original args, replacing --live with --_worker.
    worker_argv = [a for a in sys.argv[1:] if a != "--live"] + ["--_worker"]
    return subprocess.Popen(
        [sys.executable, sys.argv[0]] + worker_argv,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        stdin=subprocess.PIPE,
    )


def _start_reader_threads(proc):
    """Start daemon threads to read frames and log lines from the worker process."""
    from PIL import Image

    def _read_frames():
        while True:
            magic = proc.stdout.read(4)
            if len(magic) < 4:
                break
            if magic != b"FRME":
                continue  # out of sync — skip until we find a valid header
            header = proc.stdout.read(8)
            if len(header) < 8:
                break
            r, g, b, _, png_len = struct.unpack(">BBBBI", header)
            png_data = b""
            while len(png_data) < png_len:
                chunk = proc.stdout.read(png_len - len(png_data))
                if not chunk:
                    break
                png_data += chunk
            if len(png_data) < png_len:
                break
            statusled_sim.color = (r, g, b)
            _current_frame[0] = Image.open(io.BytesIO(png_data))

    def _read_logs():
        global _portal_mode
        for raw in proc.stderr:
            line = raw.decode(errors="replace").rstrip("\n")
            if _log_lines is not None:
                _log_lines.append(line)
            # "Portal AP: ..." is printed by portal.run() once the AP is
            # actually up and the portal is ready to accept connections.
            # Only activate the Connect client button at that point.
            if line.startswith("Portal AP:"):
                _portal_mode = True
            # Track simulated WiFi state for the Enable/Disable WiFi button.
            elif line == "[sim] Connected" or line == "[sim] WiFi enabled":
                _scheduler_wifi[0] = True
            elif line == "[sim] WiFi disabled":
                _scheduler_wifi[0] = False
            # Track DNS/ISP break state for the Break DNS / Break ISP buttons.
            elif line == "[sim] DNS broken":
                _sim_dns_broken[0] = True
            elif line == "[sim] DNS restored":
                _sim_dns_broken[0] = False
            elif line == "[sim] ISP broken":
                _sim_isp_broken[0] = True
            elif line == "[sim] ISP restored":
                _sim_isp_broken[0] = False
            sys.__stdout__.write(line + "\n")
            sys.__stdout__.flush()

    threading.Thread(target=_read_frames, daemon=True).start()
    threading.Thread(target=_read_logs,   daemon=True).start()


def _start_watcher():
    """Start an inotify_simple daemon thread that sets _restart_flag on .py changes."""
    import inotify_simple

    inotify = inotify_simple.INotify()
    flags = inotify_simple.flags.CLOSE_WRITE | inotify_simple.flags.MOVED_TO

    _py = lambda name: name.endswith(".py")
    watch_dirs = {
        str(_ROOT / "src"):            _py,
        str(_ROOT / "tests" / "simlib"): _py,
        str(_ROOT / "bin"):            lambda name: name.endswith(".py") or name == "simulate",
    }
    # lib/ contains Adafruit packages in subdirectories; inotify_simple is not
    # recursive, so enumerate every directory under lib/ at startup.
    for _d in [_ROOT / "lib", *(_ROOT / "lib").rglob("*")]:
        if _d.is_dir():
            watch_dirs[str(_d)] = _py

    wd_to_pred = {}
    for path, pred in watch_dirs.items():
        if Path(path).is_dir():
            wd = inotify.add_watch(path, flags)
            wd_to_pred[wd] = pred

    def _loop():
        while True:
            for event in inotify.read(timeout=500):
                pred = wd_to_pred.get(event.wd)
                if pred and pred(event.name):
                    print(f"[sim] {event.name} changed — restarting", flush=True)
                    _restart_flag.set()

    threading.Thread(target=_loop, daemon=True).start()


def _live_blit_matrix(img):
    """Blit a PIL Image onto the top portion of the pygame window."""
    import pygame

    mode = img.mode
    data = img.tobytes()
    surface = pygame.image.frombytes(data, img.size, mode)
    _pg_screen.blit(surface, (0, 0))


def _live_draw_panel():
    """Draw the status panel (scrolling log + neopixel dot overlay)."""
    import pygame

    panel_y = _MATRIX_H
    panel_rect = pygame.Rect(0, panel_y, _WIN_W, _PANEL_H)
    _pg_screen.fill(_PANEL_BG, panel_rect)

    # Separator between matrix and panel.
    pygame.draw.line(_pg_screen, _SEP_COL, (0, panel_y), (_WIN_W, panel_y))

    # --- Button (top-right of status panel) ---
    # Portal mode: connect/disconnect a simulated client to the AP.
    # Scheduler mode: enable/disable the simulated WiFi connection.
    btn_x = _WIN_W - _BTN_MAR - _BTN_W
    btn_y = _MATRIX_H + _BTN_MAR
    btn_rect = pygame.Rect(btn_x, btn_y, _BTN_W, _BTN_H)
    if _portal_mode:
        import sys as _sys
        _wifi = _sys.modules.get("wifi")
        connected = bool(getattr(getattr(_wifi, "radio", None), "stations_ap", 0))
        pygame.draw.rect(_pg_screen, _BTN_DISC if connected else _BTN_COL, btn_rect, border_radius=4)
        btn_label = "Disconnect client" if connected else "Connect client"
    else:
        enabled = _scheduler_wifi[0]
        pygame.draw.rect(_pg_screen, _BTN_COL if enabled else _BTN_DISC, btn_rect, border_radius=4)
        btn_label = "Disable WiFi" if enabled else "Enable WiFi"
    btn_surf = _pg_font.render(btn_label, True, _BTN_TXT)
    btn_tx = btn_x + (_BTN_W - btn_surf.get_width()) // 2
    btn_ty = btn_y + (_BTN_H - btn_surf.get_height()) // 2
    _pg_screen.blit(btn_surf, (btn_tx, btn_ty))

    # --- Reboot button (below wifi/portal button) ---
    reboot_btn_y = btn_y + _BTN_H + _BTN_MAR
    reboot_rect = pygame.Rect(btn_x, reboot_btn_y, _BTN_W, _BTN_H)
    pygame.draw.rect(_pg_screen, _REBOOT_BTN_COL, reboot_rect, border_radius=4)
    reboot_surf = _pg_font.render("Reboot", True, _BTN_TXT)
    _pg_screen.blit(reboot_surf, (
        btn_x + (_BTN_W - reboot_surf.get_width()) // 2,
        reboot_btn_y + (_BTN_H - reboot_surf.get_height()) // 2,
    ))

    # --- Break DNS / Break ISP buttons (scheduler mode only) ---
    # Grayed out when WiFi is down — DNS/ISP faults are irrelevant without a network.
    if not _portal_mode:
        wifi_up = _scheduler_wifi[0]
        dns_btn_y = reboot_btn_y + _BTN_H + _BTN_MAR
        dns_rect = pygame.Rect(btn_x, dns_btn_y, _BTN_W, _BTN_H)
        dns_broken = _sim_dns_broken[0]
        if wifi_up:
            dns_col = _BTN_DISC if dns_broken else _BTN_COL
        else:
            dns_col = _BTN_DISABLED
        pygame.draw.rect(_pg_screen, dns_col, dns_rect, border_radius=4)
        dns_surf = _pg_font.render("Restore DNS" if dns_broken else "Break DNS", True, _BTN_TXT)
        _pg_screen.blit(dns_surf, (
            btn_x + (_BTN_W - dns_surf.get_width()) // 2,
            dns_btn_y + (_BTN_H - dns_surf.get_height()) // 2,
        ))

        isp_btn_y = dns_btn_y + _BTN_H + _BTN_MAR
        isp_rect = pygame.Rect(btn_x, isp_btn_y, _BTN_W, _BTN_H)
        isp_broken = _sim_isp_broken[0]
        if wifi_up:
            isp_col = _BTN_DISC if isp_broken else _BTN_COL
        else:
            isp_col = _BTN_DISABLED
        pygame.draw.rect(_pg_screen, isp_col, isp_rect, border_radius=4)
        isp_surf = _pg_font.render("Restore ISP" if isp_broken else "Break ISP", True, _BTN_TXT)
        _pg_screen.blit(isp_surf, (
            btn_x + (_BTN_W - isp_surf.get_width()) // 2,
            isp_btn_y + (_BTN_H - isp_surf.get_height()) // 2,
        ))

    # --- Scrolling log (full width) ---
    if _log_lines is not None:
        log_x    = 8
        line_h   = _pg_font.get_linesize()
        max_lines = _PANEL_H // line_h
        all_lines = list(_log_lines)
        total     = len(all_lines)

        # Clamp scroll offset to available history.
        scroll = max(0, min(_log_scroll, max(0, total - max_lines)))

        # Slice the window: scroll=0 → newest, scroll=N → N lines back.
        end   = total - scroll if scroll > 0 else total
        start = max(0, end - max_lines)
        visible = all_lines[start:end]

        # When scrolled back, reserve one line-height at the top for the indicator.
        top_y = panel_y + (line_h + 4 if scroll > 0 else 0)

        # Render bottom-anchored; stop before the indicator row.
        y = _WIN_H - line_h - 4
        for line in reversed(visible):
            surf = _pg_font.render(line[:160], True, _TEXT_COL)
            _pg_screen.blit(surf, (log_x, y))
            y -= line_h
            if y < top_y:
                break

        # Scroll indicator: shown when not at the bottom.
        if scroll > 0:
            hidden = total - end
            label  = f"↑ {hidden} line{'s' if hidden != 1 else ''} below  (↓ / End / click to follow)"
            surf   = _pg_font.render(label, True, _DIM_COL)
            _pg_screen.blit(surf, (log_x, panel_y + 4))

    # --- Neopixel dot: small overlay in bottom-right corner of panel ---
    dot_cx    = _WIN_W - _DOT_MAR - _DOT_R
    dot_cy    = _WIN_H - _DOT_MAR - _DOT_R
    led_color = statusled_sim.color

    if led_color != statusled_sim.OFF:
        glow_r   = int(_DOT_R * 1.3)   # thin glow, just outside the dot edge
        glow_col = tuple(c // 6 for c in led_color)
        pygame.draw.circle(_pg_screen, glow_col, (dot_cx, dot_cy), glow_r)

    pygame.draw.circle(_pg_screen, led_color, (dot_cx, dot_cy), _DOT_R)


def _live_pump():
    """Process pygame events; trigger white-flash restart if watcher fired.

    Returns False if the window was closed (QUIT), True otherwise.
    """
    import pygame
    global _log_scroll

    line_h     = _pg_font.get_linesize() if _pg_font else 16
    max_lines  = _PANEL_H // line_h
    max_scroll = max(0, len(_log_lines) - max_lines) if _log_lines is not None else 0

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            return False
        elif event.type == pygame.MOUSEWHEEL:
            # Positive y = scroll up (wheel away from user) = older lines.
            # Multiply by 3 so one notch moves a few lines rather than one.
            _log_scroll = max(0, min(_log_scroll + event.y * 3, max_scroll))
        elif event.type == pygame.MOUSEBUTTONDOWN:
            if event.button == 1:  # left click only; buttons 4/5 are legacy scroll wheel
                # Check the top-right button (portal or WiFi toggle).
                btn_x = _WIN_W - _BTN_MAR - _BTN_W
                btn_y = _MATRIX_H + _BTN_MAR
                btn_rect = pygame.Rect(btn_x, btn_y, _BTN_W, _BTN_H)
                if btn_rect.collidepoint(event.pos):
                    if _portal_mode:
                        import sys as _sys
                        _wifi = _sys.modules.get("wifi")
                        if _wifi is not None:
                            # Toggle launcher's copy for button label update.
                            current = int(getattr(getattr(_wifi, "radio", None), "stations_ap", 0))
                            _wifi.radio.stations_ap = 0 if current else 1
                            state = "connected" if _wifi.radio.stations_ap else "disconnected"
                            print(f"[sim] portal: client {state}")
                        # Send toggle command to the worker subprocess so the
                        # portal's event loop sees the stations_ap change.
                        if _worker_stdin is not None:
                            try:
                                _worker_stdin.write(b"toggle-client\n")
                                _worker_stdin.flush()
                            except OSError:
                                pass
                    else:
                        # Toggle simulated WiFi in the scheduler worker.
                        _scheduler_wifi[0] = not _scheduler_wifi[0]
                        if _worker_stdin is not None:
                            try:
                                _worker_stdin.write(b"toggle-wifi\n")
                                _worker_stdin.flush()
                            except OSError:
                                pass
                    continue
                # Check the reboot button (below wifi/portal button).
                reboot_btn_y = btn_y + _BTN_H + _BTN_MAR
                reboot_rect = pygame.Rect(btn_x, reboot_btn_y, _BTN_W, _BTN_H)
                if reboot_rect.collidepoint(event.pos):
                    _reboot_requested.set()
                    continue
                # Check Break DNS / Break ISP buttons (scheduler mode only).
                # No-op when WiFi is down — buttons are grayed out.
                if not _portal_mode and _scheduler_wifi[0]:
                    dns_btn_y = reboot_btn_y + _BTN_H + _BTN_MAR
                    dns_rect = pygame.Rect(btn_x, dns_btn_y, _BTN_W, _BTN_H)
                    if dns_rect.collidepoint(event.pos):
                        _sim_dns_broken[0] = not _sim_dns_broken[0]
                        if _worker_stdin is not None:
                            try:
                                _worker_stdin.write(b"toggle-dns\n")
                                _worker_stdin.flush()
                            except OSError:
                                pass
                        continue
                    isp_btn_y = dns_btn_y + _BTN_H + _BTN_MAR
                    isp_rect = pygame.Rect(btn_x, isp_btn_y, _BTN_W, _BTN_H)
                    if isp_rect.collidepoint(event.pos):
                        _sim_isp_broken[0] = not _sim_isp_broken[0]
                        if _worker_stdin is not None:
                            try:
                                _worker_stdin.write(b"toggle-isp\n")
                                _worker_stdin.flush()
                            except OSError:
                                pass
                        continue
                _log_scroll = 0
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_UP:
                _log_scroll = min(_log_scroll + 1, max_scroll)
            elif event.key == pygame.K_DOWN:
                _log_scroll = max(_log_scroll - 1, 0)
            elif event.key == pygame.K_PAGEUP:
                _log_scroll = min(_log_scroll + max_lines, max_scroll)
            elif event.key == pygame.K_PAGEDOWN:
                _log_scroll = max(_log_scroll - max_lines, 0)
            elif event.key == pygame.K_HOME:
                _log_scroll = max_scroll
            elif event.key == pygame.K_END:
                _log_scroll = 0

    return True


def _live_event_loop(proc_ref):
    """Main pygame event loop — runs in the main thread while the worker runs in its own process.

    Blits the latest frame from _current_frame, redraws the status panel, and
    processes input at ~10 fps. Handles worker restart when _restart_flag is set.
    Keeps the window alive if the worker crashes — waits for the next file-change
    event to restart rather than exiting. Exits only when the window is closed.
    """
    import pygame

    pg_clock = pygame.time.Clock()
    crashed_notified = False
    try:
        while True:
            pg_clock.tick(10)
            if not _live_pump():
                break

            worker_alive = proc_ref[0].poll() is None

            # Restart worker if a source file changed (or if it crashed and a new
            # edit arrives — in that case skip terminate since it's already dead).
            if _restart_flag.is_set():
                _restart_flag.clear()
                crashed_notified = False
                if worker_alive:
                    proc_ref[0].terminate()
                    try:
                        proc_ref[0].wait(timeout=2)
                    except subprocess.TimeoutExpired:
                        proc_ref[0].kill()
                _pg_screen.fill((255, 255, 255))
                pygame.display.flip()
                time.sleep(0.05)
                new_proc = _start_worker_proc()
                _start_reader_threads(new_proc)
                proc_ref[0] = new_proc
                continue

            # Reboot button: kill the worker immediately (no clean shutdown —
            # matches the hardware RESET button) then restart fresh.
            if _reboot_requested.is_set():
                _reboot_requested.clear()
                crashed_notified = False
                if worker_alive:
                    proc_ref[0].kill()
                    proc_ref[0].wait()
                _pg_screen.fill((255, 255, 255))
                pygame.display.flip()
                time.sleep(0.05)
                new_proc = _start_worker_proc()
                _start_reader_threads(new_proc)
                proc_ref[0] = new_proc
                continue

            if not worker_alive:
                exit_code = proc_ref[0].poll()
                if exit_code == 0:
                    # Clean exit (settings saved — reload requested) — restart.
                    crashed_notified = False
                    _pg_screen.fill((255, 255, 255))
                    pygame.display.flip()
                    time.sleep(0.05)
                    new_proc = _start_worker_proc()
                    _start_reader_threads(new_proc)
                    proc_ref[0] = new_proc
                    continue
                # Non-zero exit: genuine crash — keep the window alive so the user
                # can read the traceback and edit the source to trigger a restart.
                if not crashed_notified:
                    if _log_lines is not None:
                        _log_lines.append("[sim] worker crashed — edit the source to restart")
                    crashed_notified = True
                _live_draw_panel()
                pygame.display.flip()
                continue

            if _current_frame[0] is not None:
                _live_blit_matrix(_current_frame[0])
            _live_draw_panel()
            pygame.display.flip()
    except KeyboardInterrupt:
        print("\n[sim] interrupted")


# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# Portal simulation helpers.
# ---------------------------------------------------------------------------

def _is_portal_mode(args):
    """Return True if the sim would enter portal mode for the given settings.

    Used by the launcher process to set ``_portal_mode`` before spawning the
    worker subprocess, so the Connect/Disconnect button appears in the live
    window even though the worker is what actually calls ``_run_portal()``.
    """
    if getattr(args, "portal", False):
        return True
    try:
        with open(args.settings, "rb") as f:
            data = tomllib.load(f)
        if data.get("FORCE_PORTAL"):
            return True
        return (not data.get("CIRCUITPY_WIFI_SSID")
                or not data.get("LATITUDE") or not data.get("LONGITUDE"))
    except (FileNotFoundError, OSError, Exception):
        return True  # missing or invalid settings file → portal mode (same as _load_config)


def _find_portal_port(explicit_port):
    """Return a free port for the portal HTTP server.

    If ``explicit_port`` is given, bind to it exactly and raise if it is taken.
    Otherwise start at 8080 and increment until a free port is found.
    """
    if explicit_port is not None:
        s = socket.socket()
        try:
            s.bind(("", explicit_port))
            s.close()
            return explicit_port
        except OSError:
            raise SystemExit(
                f"[sim] error: port {explicit_port} is already in use"
            )
    port = 8080
    while True:
        s = socket.socket()
        try:
            s.bind(("", port))
            s.close()
            return port
        except OSError:
            port += 1


def _make_sim_server(ip, initial_networks, port, settings_path=None, portal_save=False,
                     current_values=None, config_errors=None):
    """Return a stdlib HTTPServer that mirrors the adafruit_httpserver interface.

    Returns ``(server, state)`` matching the signature of portal._make_server
    so it can be used as a drop-in replacement.

    ``settings_path`` is the settings.toml path passed to the simulator.
    When ``portal_save`` is True, the merged settings are written back to
    that file after form submission (simulating the device's save-and-reload
    cycle).  When False, the merged content is printed but no file is written.

    ``current_values`` and ``config_errors`` are forwarded to ``_form_html``
    so the sim pre-populates the form and shows any config-error banner,
    matching the device behaviour.
    """
    import portal as _portal_mod

    _networks = [initial_networks]
    _current_values = [current_values or {}]
    _config_errors  = [config_errors  or {}]
    state = {"last_request_t": 0.0}

    class _Handler(BaseHTTPRequestHandler):
        def log_message(self, fmt, *a):
            print(f"[sim] HTTP {fmt % a}")

        def _send(self, body, content_type="text/html", code=200):
            enc = body.encode("utf-8")
            self.send_response(code)
            self.send_header("Content-Type", content_type + "; charset=utf-8")
            self.send_header("Content-Length", str(len(enc)))
            self.end_headers()
            self.wfile.write(enc)

        def do_GET(self):
            state["last_request_t"] = time.monotonic()
            if self.path == "/scan":
                import network as _net_mod
                _networks[0] = _net_mod.scan_networks()
                configured_ssid = _current_values[0].get('ssid') or None
                self._send(_portal_mod._ssid_options(_networks[0], configured_ssid))
            else:
                html = _portal_mod._form_html(_networks[0], _current_values[0], _config_errors[0])
                _config_errors[0] = {}  # clear after first render, matching device behaviour
                self._send(html)

        def do_POST(self):
            state["last_request_t"] = time.monotonic()
            length = int(self.headers.get("Content-Length", 0))
            if length > _portal_mod.MAX_POST_BODY_BYTES:
                self._send("<p>Request body too large.</p>", code=413)
                return
            raw = self.rfile.read(length).decode("utf-8", errors="replace")
            fields = urllib.parse.parse_qs(raw, keep_blank_values=True)
            # Flatten single-value lists the way the device handler sees them.
            parsed = {k: v[0] for k, v in fields.items()}
            print(f"[sim] form submitted: {parsed}")

            errors = _portal_mod._validate_form_data(parsed)
            if errors:
                print(f"[sim] validation errors: {errors}")
                self._send(_portal_mod._validation_error_html(errors), code=400)
                return

            try:
                old_content = Path(settings_path).read_text() if settings_path else ""
            except FileNotFoundError:
                old_content = ""
            new_content = _portal_mod.merge_settings(parsed, old_content)

            print("[sim] settings that would be written:")
            for line in new_content.splitlines():
                print(f"  {line}")

            if portal_save and settings_path:
                Path(settings_path).write_text(new_content)
                print(f"[sim] wrote {settings_path}")
            elif not settings_path:
                print("[sim] (no file written — no settings path provided)")
            else:
                print(f"[sim] (no file written — rerun with --portal-save to update {settings_path})")

            state["reload_pending"] = True
            self._send(_portal_mod._success_html(new_content))

    srv = HTTPServer(("", port), _Handler)
    srv.timeout = 0.05   # non-blocking poll timeout

    class _ServerShim:
        """Thin wrapper so portal.run()'s server.poll() call works."""
        def poll(self):
            srv.handle_request()

    return _ServerShim(), state


def _run_portal(args, config):
    """Run portal.run() with the stdlib server shim and display-refresh hook.

    Returns True if portal exited via a save/reload request, False if interrupted.
    """
    global _portal_mode
    reload_requested = False
    _portal_mode = True
    port = _find_portal_port(args.port)
    url = f"http://127.0.0.1:{port}"
    print(f"[sim] portal server: {url}")

    # Override ipv4_address_ap so the URL QR points to the machine's LAN IP + port.
    # network.ap_ip() returns str(wifi.radio.ipv4_address_ap) directly.
    _lan_ip = _get_lan_ip()
    _wifi.radio.ipv4_address_ap = f"{_lan_ip}:{port}"
    print(f"[sim] portal reachable at http://{_lan_ip}:{port}")

    # Patch url_qr_data to omit the extra ":80" suffix (already in ap_ip).
    import portal as _portal_mod
    _portal_mod.url_qr_data = lambda ip: f"http://{ip}"

    # Log save mode up front so the user knows before going through setup.
    if getattr(args, "portal_save", False):
        print(f"[sim] portal save mode: ON — form submissions will update {args.settings}")
    else:
        print(f"[sim] portal save mode: OFF — pass --portal-save to update {args.settings}")

    # Replace _make_server with our stdlib shim.
    _portal_mod._make_server = lambda ip, nets, current_values=None, config_errors=None: _make_sim_server(
        ip, nets, port,
        settings_path=args.settings,
        portal_save=getattr(args, "portal_save", False),
        current_values=current_values,
        config_errors=config_errors,
    )

    # Patch supervisor.reload so a successful save exits the sim cleanly
    # instead of trying to reboot the (nonexistent) hardware.
    import supervisor as _supervisor_mod
    def _sim_reload():
        raise _SimStop("settings saved — restarting")
    _supervisor_mod.reload = _sim_reload

    if getattr(args, "fake_usb", False):
        _supervisor_mod.runtime.usb_connected = True
        print("[sim] --fake-usb: simulating USB cable connected")

    # Capture the SimDisplay so we can trigger frame saves via the
    # existing _refresh_and_save hook patched onto SimDisplay.refresh.
    _sim_display = [None]

    # Patch display_set_root to capture the SimDisplay reference.
    import matrix_sim as _matrix_sim
    _orig_dsr = _matrix_sim.display_set_root
    def _capturing_dsr(root_group, **kw):
        sim_disp = _orig_dsr(root_group, **kw)
        _sim_display[0] = sim_disp
        return sim_disp
    _matrix_sim.display_set_root = _capturing_dsr

    # Refresh the display after each group mutation so PNG frames are emitted.
    from displayio_sim import Group
    _orig_append = Group.append
    _orig_pop = Group.pop
    def _append_and_refresh(self, item):
        _orig_append(self, item)
        if _sim_display[0]:
            _sim_display[0].refresh()
    def _pop_and_refresh(self):
        result = _orig_pop(self)
        if _sim_display[0]:
            _sim_display[0].refresh()
        return result
    Group.append = _append_and_refresh
    Group.pop = _pop_and_refresh

    _portal_rendering_active[0] = True
    try:
        if args.live:
            # In --live mode the pygame event loop runs in the main thread;
            # portal.run() must be in a daemon thread so it doesn't block it.
            # The sim never enters recovery mode (no PortalNeeded path).
            portal_thread = threading.Thread(
                target=_portal_mod.run, args=(config,), daemon=True, name="portal"
            )
            portal_thread.start()
            try:
                _live_event_loop(portal_thread)
            finally:
                import pygame
                pygame.quit()
        else:
            # If running as a worker subprocess, start a stdin-listener thread
            # so the launcher can toggle wifi.radio.stations_ap by writing
            # "toggle-client\n".  This replaces the direct shared-memory access
            # that worked when the portal ran as a daemon thread in one process.
            if getattr(args, "_worker", False):
                import wifi as _wifi_mod

                def _stdin_listener():
                    try:
                        for raw_line in sys.stdin:
                            if raw_line.strip() == "toggle-client":
                                current = bool(
                                    getattr(getattr(_wifi_mod, "radio", None), "stations_ap", 0)
                                )
                                _wifi_mod.radio.stations_ap = 0 if current else 1
                                state = "connected" if _wifi_mod.radio.stations_ap else "disconnected"
                                print(f"[sim] portal: client {state}")
                    except (OSError, EOFError):
                        pass  # stdin closed — worker is shutting down

                threading.Thread(target=_stdin_listener, daemon=True, name="portal-stdin").start()

            # The sim never enters recovery mode (no PortalNeeded path exists
            # here — broken-wifi runs the scheduler loop and never escalates).
            _portal_mod.run(config, recovery=False)
    except _SimStop as e:
        print(f"\n[sim] {e}")
        reload_requested = True
    except KeyboardInterrupt:
        print("\n[sim] portal interrupted")
    finally:
        _portal_rendering_active[0] = False
        # Restore Group methods patched for frame emission.
        Group.append = _orig_append
        Group.pop = _orig_pop
        _matrix_sim.display_set_root = _orig_dsr
    return reload_requested


# ---------------------------------------------------------------------------
# Entry point.
# ---------------------------------------------------------------------------
class _SimStop(Exception):
    """Raised by the patched Clock.wait to exit the scheduler loop cleanly."""


def _run_scheduler_main(args):
    """Shared setup and execution for worker and headless modes.

    Both modes run the scheduler directly in the calling thread. They differ
    only in what _refresh_and_save does with each rendered frame.
    """
    output    = args.output
    scale     = args.scale
    is_worker = getattr(args, "_worker", False)

    # In worker mode, save the raw stdout fd for frame output and redirect
    # print() to stderr so the launcher can capture log lines separately.
    if is_worker:
        _frame_out = sys.stdout.buffer
        sys.stdout = sys.stderr
    else:
        _frame_out = None

    # --- Trace directory setup -------------------------------------------
    trace_dir = None
    if args.trace is not None:
        if args.tmpdir:
            trace_dir = tempfile.mkdtemp(prefix="weatherpanel-")
            print(f"[sim] trace directory: {trace_dir}", flush=True)
        elif args.trace is True:
            _build_parser().error("--trace requires a DIR argument or --tmpdir")
        else:
            trace_dir = args.trace
            os.makedirs(trace_dir, exist_ok=True)
            print(f"[sim] trace directory: {trace_dir}", flush=True)
    elif args.tmpdir:
        _build_parser().error("--tmpdir requires --trace")

    config = _load_config(args.settings)

    # --- Wi-Fi simulation ------------------------------------------------
    # network.check() reads wifi.radio.connected directly; network.connect()
    # calls wifi.radio.connect(ssid, password).  We start disconnected and
    # wire wifi.radio.connect to do the simulated delay then set the flag.
    # The scheduler's RETRY_DELAY_S is skipped on first connect (it lives in
    # the else branch of run()'s failure handler), so the only startup delay
    # the user sees is wifi_delay itself.
    _wifi_delay = args.wifi_delay
    _wifi.radio.connected = False

    # _wifi_enabled tracks the simulated external network condition — distinct
    # from wifi.radio.connected ("is the radio currently associated?").  When
    # False, connect() raises ConnectionError exactly as real hardware does
    # when the AP is unreachable.  Only used in non-broken-wifi mode.
    _wifi_enabled = [True]

    if args.broken_wifi:
        def _sim_wifi_connect(ssid, password=None):
            print(f"[sim] Trying to connect to {ssid} (broken — will not connect)")
            time.sleep(_wifi_delay)
            print("[sim] Connect failed (--broken-wifi)")
        _wifi.radio.connect = _sim_wifi_connect
    else:
        def _sim_wifi_connect(ssid, password=None):
            if not _wifi_enabled[0]:
                print(f"[sim] Trying to connect to {ssid} (network down)")
                time.sleep(_wifi_delay)
                raise ConnectionError("[sim] network unavailable")
            print(f"[sim] Connecting to {ssid} ({_wifi_delay:.1f}s simulated delay)...")
            time.sleep(_wifi_delay)
            _wifi.radio.connected = True
            _wifi.radio.ap_info = types.SimpleNamespace(ssid=ssid)
            print("[sim] Connected")
        _wifi.radio.connect = _sim_wifi_connect

    # Shared between clock.wait() and the stdin listener so any toggle command
    # wakes the scheduler immediately rather than waiting up to 59 s for the
    # natural sleep to expire.
    _wake_event = threading.Event()

    # In worker mode, install socket-level intercepts and listen for commands
    # from the launcher process.
    # "toggle-wifi":  simulate a network outage/recovery (not meaningful in
    #   broken-wifi mode, where the network never connects anyway).
    # "toggle-dns":   patch socket.getaddrinfo to raise gaierror — WiFi stays
    #   up but every hostname lookup fails, exactly as if the DNS server is gone.
    # "toggle-isp":   use a socket.socket subclass whose connect() raises
    #   ETIMEDOUT for non-loopback addresses — DNS still resolves but TCP
    #   connections time out, as when the upstream link is dead.
    if is_worker:
        import network as _network_mod
        import socket as _socket_mod
        _dns_broken = [False]
        _isp_broken = [False]

        # --- DNS break: patch socket.getaddrinfo ----------------------------
        # Also checked when WiFi is disabled — all name resolution fails when
        # the network interface is down, just like on real hardware.
        _orig_getaddrinfo = _socket_mod.getaddrinfo

        def _sim_getaddrinfo(host, port, *args, **kwargs):
            if host not in ("localhost", "127.0.0.1", "::1"):
                if not _wifi_enabled[0]:
                    raise _socket_mod.gaierror(-3, "Temporary failure in name resolution")
                if _dns_broken[0]:
                    raise _socket_mod.gaierror(-2, "Name or service not known")
            return _orig_getaddrinfo(host, port, *args, **kwargs)

        _socket_mod.getaddrinfo = _sim_getaddrinfo

        # --- ISP break: replace socket.socket with a flag-checking subclass --
        # Also checked when WiFi is disabled as a belt-and-suspenders for any
        # connection attempt that bypasses getaddrinfo (e.g. literal IP addresses).
        _OrigSocket = _socket_mod.socket

        class _SimSocket(_OrigSocket):
            def connect(self, address):
                host = address[0] if isinstance(address, (tuple, list)) else str(address)
                if host not in ("localhost", "127.0.0.1", "::1"):
                    if not _wifi_enabled[0]:
                        raise OSError(101, "Network is unreachable")
                    if _isp_broken[0]:
                        raise OSError(110, "Connection timed out")
                return super().connect(address)

            def connect_ex(self, address):
                host = address[0] if isinstance(address, (tuple, list)) else str(address)
                if host not in ("localhost", "127.0.0.1", "::1"):
                    if not _wifi_enabled[0]:
                        return 101  # ENETUNREACH
                    if _isp_broken[0]:
                        return 110  # ETIMEDOUT
                return super().connect_ex(address)

        _socket_mod.socket = _SimSocket

        def _stdin_listener():
            try:
                for raw_line in sys.stdin:
                    cmd = raw_line.strip()
                    if cmd == "toggle-wifi" and not args.broken_wifi:
                        _wifi_enabled[0] = not _wifi_enabled[0]
                        if not _wifi_enabled[0]:
                            # Drop the connection and kill the socket pool so
                            # any in-flight request sees an OSError immediately,
                            # matching what real hardware does when the AP drops.
                            _wifi.radio.connected = False
                            _network_mod._reset_session()
                            print("[sim] WiFi disabled")
                        else:
                            # Re-enable: leave connected=False so the scheduler's
                            # next connect() call succeeds naturally and prints
                            # "[sim] Connected", which flips the launcher's button.
                            print("[sim] WiFi enabled")
                        # Wake clock.wait() so the scheduler reacts immediately
                        # rather than sleeping out the rest of the current minute.
                        _wake_event.set()
                    elif cmd == "toggle-dns":
                        _dns_broken[0] = not _dns_broken[0]
                        # Reset the session to close any in-flight sockets so the
                        # next request starts fresh and immediately hits the patch.
                        _network_mod._reset_session()
                        print("[sim] DNS broken" if _dns_broken[0] else "[sim] DNS restored")
                        _wake_event.set()
                    elif cmd == "toggle-isp":
                        _isp_broken[0] = not _isp_broken[0]
                        _network_mod._reset_session()
                        print("[sim] ISP broken" if _isp_broken[0] else "[sim] ISP restored")
                        _wake_event.set()
            except (OSError, EOFError):
                pass  # stdin closed — worker is shutting down
        threading.Thread(
            target=_stdin_listener, daemon=True, name="scheduler-stdin",
        ).start()

    # --- Duration deadline -----------------------------------------------
    _start = time.monotonic()

    def _deadline_check():
        if args.duration and time.monotonic() - _start >= args.duration:
            raise _SimStop(f"--duration: {args.duration}s elapsed")

    # --- --until-ready ---------------------------------------------------
    _ready = [False]
    if args.until_ready:
        import display as _display_mod
        _orig_uhf = _display_mod.Display.update_hourly_forecast
        def _patched_uhf(self, hourly_data, historical_data, current_time):
            n = _orig_uhf(self, hourly_data, historical_data, current_time)
            if n and all(s is not None for s in historical_data):
                _ready[0] = True
            return n
        _display_mod.Display.update_hourly_forecast = _patched_uhf

    # --- Capture runtime objects for state snapshots ---------------------
    _rt = {'station': None, 'clock': None, 'display': None, 'led': None}

    import display as _display_mod
    import clock as _clock_mod
    import station as _station_mod

    _orig_Display = _display_mod.Display
    _orig_Clock   = _clock_mod.Clock
    _orig_Station = _station_mod.Station

    class _TrackDisplay(_orig_Display):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['display'] = self

    class _TrackClock(_orig_Clock):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['clock'] = self

    class _TrackStation(_orig_Station):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['station'] = self

    _display_mod.Display  = _TrackDisplay
    _clock_mod.Clock      = _TrackClock
    _station_mod.Station  = _TrackStation

    _orig_LED = statusled_sim.StatusLED
    class _TrackLED(_orig_LED):
        def __init__(self):
            super().__init__()
            _rt['led'] = self

        def _trigger_refresh(self):
            """Emit a frame when the LED color changes, even if display pixels are unchanged."""
            d = _rt.get('display')
            if d is not None:
                d._display.refresh()

        def working(self, c):
            old = statusled_sim.color
            super().working(c)
            if statusled_sim.color != old:
                self._trigger_refresh()

        def success(self):
            old = statusled_sim.color
            super().success()
            if statusled_sim.color != old:
                self._trigger_refresh()

        def failure(self):
            old = statusled_sim.color
            super().failure()
            if statusled_sim.color != old:
                self._trigger_refresh()

        def wifi_down(self):
            old = statusled_sim.color
            super().wifi_down()
            if statusled_sim.color != old:
                self._trigger_refresh()

        def idle(self):
            old = statusled_sim.color
            super().idle()
            if statusled_sim.color != old:
                self._trigger_refresh()

        def clear(self):
            old = statusled_sim.color
            super().clear()
            if statusled_sim.color != old:
                self._trigger_refresh()

    statusled_sim.StatusLED = _TrackLED

    from state_snapshot import make_png_info, snapshot_state

    # --- Refresh hook ----------------------------------------------------
    _orig_refresh   = matrix_sim.SimDisplay.refresh
    _last_pixels    = [None]
    _last_led_color = [None]
    _frame_counter  = [None, -1]

    def _refresh_and_save(self):
        _orig_refresh(self)
        pixels = self.render_to_pixels()
        current_led = statusled_sim.color
        if pixels == _last_pixels[0] and current_led == _last_led_color[0]:
            _deadline_check()
            return
        _last_pixels[0]    = [row[:] for row in pixels]
        _last_led_color[0] = current_led
        if args.flat or _portal_rendering_active[0]:
            img = self.render_to_image(scale=scale)
        else:
            img = self.render_to_realistic_image(cell_size=scale)
            if not args.no_vivid:
                img = _led_vivid(img)

        if is_worker:
            # Send frame to launcher via stdout pipe.
            buf = io.BytesIO()
            img.save(buf, format="PNG")
            png_bytes = buf.getvalue()
            r, g, b   = statusled_sim.color
            _frame_out.write(b"FRME" + struct.pack(">BBBBI", r, g, b, 0, len(png_bytes)) + png_bytes)
            _frame_out.flush()
        else:
            # Headless: update the shared frame slot (unused in headless, harmless).
            _current_frame[0] = img

        state    = snapshot_state(station=_rt['station'], clock=_rt['clock'],
                                  display=_rt['display'], led=_rt['led'])
        pnginfo  = make_png_info(state) if state else None

        if trace_dir:
            now     = datetime.now()
            sec_key = now.strftime("%y%m%d-%H%M%S")
            if sec_key != _frame_counter[0]:
                _frame_counter[0] = sec_key
                _frame_counter[1] = 0
            else:
                _frame_counter[1] += 1
            fname = f"{sec_key}-{_frame_counter[1]:02d}.png"
            img.save(os.path.join(trace_dir, fname), pnginfo=pnginfo)
            print(f"[sim] frame {fname}", flush=True)
        elif not is_worker:
            img.save(output, pnginfo=pnginfo)
            print(f"[sim] wrote {output}")

        _deadline_check()
        if args.until_ready and _ready[0]:
            raise _SimStop("--until-ready: first complete render done")

    matrix_sim.SimDisplay.refresh = _refresh_and_save

    # --- Interruptible sleep patches -------------------------------------
    # _wake_event lets the stdin listener interrupt both clock.wait() and the
    # scheduler's RETRY_DELAY_S sleep so any button toggle takes effect
    # immediately — not after the current sleep expires.
    #
    # scheduler.sleep is patched here (not in the is_worker block) so that it
    # is also interruptible in headless mode; in that mode _wake_event is never
    # set so _wake_event.wait() always times out normally, which is equivalent
    # to time.sleep().
    import scheduler as _scheduler_mod

    def _interruptible_sleep(seconds):
        _wake_event.wait(timeout=seconds)
        _wake_event.clear()

    _scheduler_mod.sleep = _interruptible_sleep

    import clock as _clock_module

    if args.once:
        def _wait(self):
            raise _SimStop("--once: first cycle complete")
    elif args.fast:
        def _wait(self):
            _deadline_check()
            _wake_event.clear()
            _wake_event.wait(timeout=5)
    else:
        def _wait(self):
            _deadline_check()
            t = time.localtime()
            s = t.tm_sec
            m = t.tm_min
            print(f"Waiting from :{s:02} to :59")
            _wake_event.clear()
            woken_early = _wake_event.wait(timeout=max(0, 59 - s))
            if not woken_early:
                # Reached :59 naturally — spin for precise minute rollover.
                print("Burning the last second.")
                while time.localtime().tm_min == m:
                    pass
            print(self.isotime)
    _clock_module.Clock.wait = _wait

    # --- Portal mode (--portal or unconfigured WiFi) ----------------------
    # Loop: after a save/reload the new config may graduate to scheduler mode,
    # or may still need the portal if the user left required fields blank.
    while (getattr(args, "portal", False) or config.get("FORCE_PORTAL")
           or not config.get("CIRCUITPY_WIFI_SSID")
           or not config.get("LATITUDE") or not config.get("LONGITUDE")):
        if not _run_portal(args, config):
            return    # interrupted — don't restart
        config = _load_config(args.settings)

    # Install the SIGALRM-based watchdog only in headless mode. In --live mode
    # the scheduler runs in a daemon thread and SIGALRM fires in the main
    # thread (pygame event loop), not in the scheduler — so skip it.
    if not args.live:
        install_sim_watchdog()

    while True:
        try:
            import scheduler
            break
        except (SyntaxError, ImportError) as exc:
            print(f"[sim] scheduler import failed ({exc}) — retrying in 30 s", flush=True)
            sys.modules.pop("scheduler", None)
            try:
                time.sleep(30)
            except KeyboardInterrupt:
                print("\n[sim] interrupted", flush=True)
                return

    try:
        scheduler.run(config)
    except _SimStop as e:
        print(f"[sim] {e}", flush=True)
    except KeyboardInterrupt:
        print("\n[sim] interrupted", flush=True)
    finally:
        if trace_dir:
            print(f"[sim] trace directory: {trace_dir}", flush=True)


def main():
    args = _build_parser().parse_args()

    # --- Worker subprocess: run scheduler, pipe frames to launcher -------
    if getattr(args, "_worker", False):
        _run_scheduler_main(args)
        return

    # --- Launcher: own the window, spawn and manage the worker -----------
    if args.live:
        _live_init()
        _start_watcher()
        proc_ref = [_start_worker_proc()]
        _start_reader_threads(proc_ref[0])
        global _worker_stdin
        _worker_stdin = proc_ref[0].stdin
        # _portal_mode is set to True by _start_reader_threads when it sees
        # "Portal AP:" in the worker's stderr — i.e., only once the AP is up.
        try:
            _live_event_loop(proc_ref)
        finally:
            proc_ref[0].terminate()
            try:
                proc_ref[0].wait(timeout=2)
            except subprocess.TimeoutExpired:
                proc_ref[0].kill()
            import pygame
            pygame.quit()
        return

    # --- Headless: run scheduler directly in this process ----------------
    if args.trace is None and args.tmpdir:
        _build_parser().error("--tmpdir requires --trace")
    _run_scheduler_main(args)


if __name__ == "__main__":
    main()
