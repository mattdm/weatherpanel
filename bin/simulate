#!/usr/bin/env python3
"""Run the weatherpanel scheduler on a desktop/laptop, writing display.png on
every display refresh.

Usage:
    bin/simulate settings.toml [options]

Options:
    --output PATH      Where to write the PNG (default: display.png)
    --scale N          Cell size in screen pixels per LED (default: 20 → 1280×640)
    --flat             Use flat block pixels instead of the realistic LED dot renderer
    --fast             Replace the minute-boundary wait with a 5-second sleep
    --live             Open a Wayland/SDL2 window; watch source files and restart on changes
    --once             Exit cleanly after the first display refresh cycle
    --trace DIR        Write each distinct frame as a timestamped PNG to DIR
    --tmpdir           Create a temp directory, print its path, and trace frames there
    --duration N       Exit after N seconds
    --until-ready      Exit after the first full render with hourly + historical data

The settings.toml is the same file used on the device. All keys are optional;
the same defaults as code.py apply. The scheduler makes real HTTP calls to the
weather APIs using the Python requests library in place of adafruit_requests.
"""
import argparse
import collections
import os
import sys
import tempfile
import threading
import time
import tomllib
import types
from datetime import datetime
from pathlib import Path

# ---------------------------------------------------------------------------
# sys.path: stubs and sim modules live in tests/, src/ has the real code,
# lib/ has the real Adafruit .py libraries.
# ---------------------------------------------------------------------------
_ROOT = Path(__file__).parent.parent
sys.path.insert(0, str(_ROOT / "tests"))
sys.path.insert(0, str(_ROOT / "src"))
sys.path.insert(0, str(_ROOT / "lib"))

# ---------------------------------------------------------------------------
# Hardware stubs — must be in sys.modules before any src/ import.
# ---------------------------------------------------------------------------
from sim_stubs import install_sim_watchdog, setup_hardware  # noqa: E402

setup_hardware()
# install_sim_watchdog() is called in main() — not here — so it can be
# skipped when --live is active (SIGALRM must fire in the main thread,
# which in live mode is the pygame event loop, not the scheduler).

# displayio: real sim implementation.
import displayio_sim  # noqa: E402
sys.modules["displayio"] = displayio_sim

# matrix: real sim (SimDisplay, display_set_root).
import matrix_sim  # noqa: E402
sys.modules["matrix"] = matrix_sim

# statusled: sim that records the current LED color instead of driving hardware.
import statusled_sim  # noqa: E402
sys.modules["statusled"] = statusled_sim

# ---------------------------------------------------------------------------
# Font path redirect — device fonts live at /fonts/; on a desktop machine
# they live at <repo>/fonts/.  Same pattern as the sim_display pytest fixture.
# ---------------------------------------------------------------------------
import adafruit_bitmap_font.bitmap_font as _bmp_font  # noqa: E402

_FONTS_DIR = _ROOT / "fonts"
_orig_load_font = _bmp_font.load_font
_bmp_font.load_font = lambda p: _orig_load_font(str(_FONTS_DIR / Path(p).name))

# ---------------------------------------------------------------------------
# Network shim — replace src/network.py with a requests-based module so the
# scheduler, station, and clock modules all use CPython HTTP transparently.
# ---------------------------------------------------------------------------
import requests as _requests  # noqa: E402

_network = types.ModuleType("network")
_network.user_agent = None


class _FakeNTP:
    @property
    def datetime(self):
        return time.localtime()


def _net_headers():
    h = {"Accept": "application/json"}
    if _network.user_agent:
        h["User-Agent"] = _network.user_agent
    return h


def _net_get(url):
    try:
        print(f"GET {url} ", end="", flush=True)
        r = _requests.get(url, headers=_net_headers(), timeout=15)
        if r.status_code != 200:
            print(f"HTTP {r.status_code}")
            return None
        print("OK")
        return r.json()
    except Exception as exc:
        print(f"Error: {exc}")
        return None


def _net_post(url, querydata):
    try:
        print(f"POST {url} ", end="", flush=True)
        r = _requests.post(url, headers=_net_headers(), json=querydata, timeout=15)
        if r.status_code != 200:
            print(f"HTTP {r.status_code}")
            return None
        print("OK")
        return r.json()
    except Exception as exc:
        print(f"Error: {exc}")
        return None


_network.get = _net_get
_network.post = _net_post
_network.check = lambda: "simulated"
_network.connect = lambda config: None
_network.ntp = lambda: _FakeNTP()
sys.modules["network"] = _network


# ---------------------------------------------------------------------------
# Parse arguments and load settings.toml.
# ---------------------------------------------------------------------------
def _build_parser():
    p = argparse.ArgumentParser(
        description="Run the weatherpanel scheduler and write display.png on each refresh."
    )
    p.add_argument("settings", metavar="settings.toml",
                   help="Path to a settings.toml (same file used on the device)")
    p.add_argument("--output", default="display.png", metavar="PATH",
                   help="Output PNG path (default: display.png); ignored with --trace or --tmpdir")
    p.add_argument("--scale", type=int, default=20, metavar="N",
                   help="Cell size in screen pixels per LED (default: 20 → 1280×640)")
    p.add_argument("--flat", action="store_true",
                   help="Use flat block pixels instead of the realistic LED dot renderer")
    p.add_argument("--fast", action="store_true",
                   help="Replace the minute wait with a 5-second sleep")
    p.add_argument("--live", action="store_true",
                   help="Open a Wayland/SDL2 window and restart automatically on source changes")
    p.add_argument("--once", action="store_true",
                   help="Exit cleanly after the first display refresh cycle")
    p.add_argument("--trace", nargs="?", const=True, metavar="DIR",
                   help="Write each distinct frame as a timestamped PNG; "
                        "optionally specify DIR (use with --tmpdir if no DIR given)")
    p.add_argument("--tmpdir", action="store_true",
                   help="Auto-create a temp directory for --trace output and print its path")
    p.add_argument("--duration", type=float, metavar="N",
                   help="Exit after N seconds")
    p.add_argument("--until-ready", action="store_true", dest="until_ready",
                   help="Exit after the first full render (hourly + all historical data present)")
    return p


def _load_config(settings_path):
    """Build the config dict from defaults and a settings.toml, matching code.py."""
    config = {
        "CIRCUITPY_WIFI_SSID": "change me in settings.toml",
        "CIRCUITPY_WIFI_PASSWORD": "change me in settings.toml",
        "USER_AGENT": "weatherpanel (codeberg.org/mattdm/weatherpanel)",
        "GEOLOCATION_API": "http://ip-api.com/json/",
        "GRIDPOINT_API": "https://api.weather.gov/points",
        "HISTORICAL_API": "https://data.rcc-acis.org/GridData",
        "LATITUDE": None,
        "LONGITUDE": None,
        "SWAP_GREEN_BLUE": False,
        "RELOAD_ON_ERROR": False,
        "TEMP_SCALE_RANGE": 110,
        "TEMP_MIDPOINT": 50,
        "CLOCK_TWENTYFOUR": False,
        "CLOCK_DELIMITER": ":",
    }
    _SECRETS = {"CIRCUITPY_WIFI_PASSWORD"}
    _BOOL_KEYS = ("SWAP_GREEN_BLUE", "RELOAD_ON_ERROR", "CLOCK_TWENTYFOUR")
    _INT_KEYS = ("TEMP_SCALE_RANGE", "TEMP_MIDPOINT")

    with open(settings_path, "rb") as f:
        toml_values = tomllib.load(f)

    for key in config:
        if key in toml_values:
            config[key] = toml_values[key]
            if key in _SECRETS:
                print(f"{key} = '****'")
            else:
                print(f"{key} = '{config[key]}'")
        else:
            print(f"{key} = '{config[key]}' (default)")

    for key in _BOOL_KEYS:
        v = config[key]
        if isinstance(v, str):
            config[key] = v.lower() not in ("0", "false", "no", "")
    for key in _INT_KEYS:
        config[key] = int(config[key])

    return config


# ---------------------------------------------------------------------------
# Live window — only used when --live is active.
# ---------------------------------------------------------------------------

# Layout constants (set at init time, after --scale is known).
_WIN_W    = 1280
_WIN_H    = 1024
_MATRIX_H = 640   # 32 rows × scale=20
_PANEL_H  = _WIN_H - _MATRIX_H   # 384px for the status panel

# Neopixel dot: small overlay in the top-right corner of the log area.
# Radius matches one matrix pixel at default scale=20 (dot_fraction 0.8 → 8px).
_DOT_R   = 8
_DOT_MAR = 6   # margin from panel edges

# Colors for the status panel chrome.
_PANEL_BG  = (15,  15,  15)
_SEP_COL   = (50,  50,  50)
_DIM_COL   = (90,  90,  90)
_TEXT_COL  = (185, 185, 185)

_pg_screen     = None              # pygame.Surface
_log_lines     = None              # deque[str] — captured stdout
_pg_font       = None              # pygame.font.Font for log text
_log_scroll    = 0                 # lines scrolled back from the bottom (0 = newest)
_current_frame = [None]            # latest PIL Image from the scheduler thread
_restart_flag  = threading.Event() # set by watcher thread, consumed in main thread


class _TeeSysout:
    """Wraps sys.stdout to tee every line into the live log deque."""

    def __init__(self, real_out, buf):
        self._real = real_out
        self._buf  = buf
        self._pending = ""

    def write(self, text):
        global _log_scroll
        self._real.write(text)
        self._pending += text
        while "\n" in self._pending:
            line, self._pending = self._pending.split("\n", 1)
            self._buf.append(line)

    def flush(self):
        self._real.flush()

    def fileno(self):
        return self._real.fileno()


def _live_init(matrix_w, matrix_h):
    """Initialize the pygame window and inotify watcher."""
    global _pg_screen, _log_lines, _pg_font

    # Suppress pygame's startup chatter before importing it.
    import warnings
    warnings.filterwarnings("ignore", category=UserWarning,      module="pygame.pkgdata")
    warnings.filterwarnings("ignore", category=DeprecationWarning, module="pkg_resources")
    warnings.filterwarnings("ignore", category=DeprecationWarning, module="pygame")
    os.environ["PYGAME_HIDE_SUPPORT_PROMPT"] = "1"
    os.environ.setdefault("SDL_VIDEODRIVER", "wayland")

    import pygame

    # Redirect stderr at the fd level around pygame.init() to swallow native
    # library noise such as the Gtk "Failed to load module" message.
    _stderr_fd = os.dup(2)
    with open(os.devnull, "w") as _null:
        os.dup2(_null.fileno(), 2)
        try:
            pygame.init()
        finally:
            os.dup2(_stderr_fd, 2)
            os.close(_stderr_fd)
    pygame.display.set_caption("weatherpanel")
    _pg_screen = pygame.display.set_mode((_WIN_W, _WIN_H))

    _pg_font = pygame.font.SysFont("monospace", 13)
    pygame.key.set_repeat(300, 50)

    _log_lines = collections.deque(maxlen=300)
    sys.stdout = _TeeSysout(sys.__stdout__, _log_lines)

    _start_watcher()
    _live_draw_panel()
    pygame.display.flip()


def _start_watcher():
    """Start an inotify_simple daemon thread that sets _restart_flag on .py changes."""
    import inotify_simple

    inotify = inotify_simple.INotify()
    flags = inotify_simple.flags.CLOSE_WRITE | inotify_simple.flags.MOVED_TO

    watch_dirs = {
        str(_ROOT / "src"):   lambda name: name.endswith(".py"),
        str(_ROOT / "tests"): lambda name: name.endswith(".py"),
        str(_ROOT / "bin"):   lambda name: name.endswith(".py") or name == "simulate",
    }
    wd_to_pred = {}
    for path, pred in watch_dirs.items():
        if Path(path).is_dir():
            wd = inotify.add_watch(path, flags)
            wd_to_pred[wd] = pred

    def _loop():
        while True:
            for event in inotify.read(timeout=500):
                pred = wd_to_pred.get(event.wd)
                if pred and pred(event.name):
                    print(f"[sim] {event.name} changed — restarting", flush=True)
                    _restart_flag.set()

    threading.Thread(target=_loop, daemon=True).start()


def _live_blit_matrix(img):
    """Blit a PIL Image onto the top portion of the pygame window."""
    import pygame

    mode = img.mode
    data = img.tobytes()
    surface = pygame.image.frombytes(data, img.size, mode)
    _pg_screen.blit(surface, (0, 0))


def _live_draw_panel():
    """Draw the status panel (scrolling log + neopixel dot overlay)."""
    import pygame

    panel_y = _MATRIX_H
    panel_rect = pygame.Rect(0, panel_y, _WIN_W, _PANEL_H)
    _pg_screen.fill(_PANEL_BG, panel_rect)

    # Separator between matrix and panel.
    pygame.draw.line(_pg_screen, _SEP_COL, (0, panel_y), (_WIN_W, panel_y))

    # --- Scrolling log (full width) ---
    if _log_lines is not None:
        log_x    = 8
        line_h   = _pg_font.get_linesize()
        max_lines = _PANEL_H // line_h
        all_lines = list(_log_lines)
        total     = len(all_lines)

        # Clamp scroll offset to available history.
        scroll = max(0, min(_log_scroll, max(0, total - max_lines)))

        # Slice the window: scroll=0 → newest, scroll=N → N lines back.
        end   = total - scroll if scroll > 0 else total
        start = max(0, end - max_lines)
        visible = all_lines[start:end]

        # When scrolled back, reserve one line-height at the top for the indicator.
        top_y = panel_y + (line_h + 4 if scroll > 0 else 0)

        # Render bottom-anchored; stop before the indicator row.
        y = _WIN_H - line_h - 4
        for line in reversed(visible):
            surf = _pg_font.render(line[:160], True, _TEXT_COL)
            _pg_screen.blit(surf, (log_x, y))
            y -= line_h
            if y < top_y:
                break

        # Scroll indicator: shown when not at the bottom.
        if scroll > 0:
            hidden = total - end
            label  = f"↑ {hidden} line{'s' if hidden != 1 else ''} below  (↓ / End / click to follow)"
            surf   = _pg_font.render(label, True, _DIM_COL)
            _pg_screen.blit(surf, (log_x, panel_y + 4))

    # --- Neopixel dot: small overlay in bottom-right corner of panel ---
    dot_cx    = _WIN_W - _DOT_MAR - _DOT_R
    dot_cy    = _WIN_H - _DOT_MAR - _DOT_R
    led_color = statusled_sim.color

    if led_color != statusled_sim.OFF:
        glow_r   = int(_DOT_R * 1.3)   # thin glow, just outside the dot edge
        glow_col = tuple(c // 6 for c in led_color)
        pygame.draw.circle(_pg_screen, glow_col, (dot_cx, dot_cy), glow_r)

    pygame.draw.circle(_pg_screen, led_color, (dot_cx, dot_cy), _DOT_R)


def _live_pump():
    """Process pygame events; trigger white-flash restart if watcher fired.

    Returns False if the window was closed (QUIT), True otherwise.
    """
    import pygame
    global _log_scroll

    line_h     = _pg_font.get_linesize() if _pg_font else 16
    max_lines  = _PANEL_H // line_h
    max_scroll = max(0, len(_log_lines) - max_lines) if _log_lines is not None else 0

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            return False
        elif event.type == pygame.MOUSEWHEEL:
            # Positive y = scroll up (wheel away from user) = older lines.
            # Multiply by 3 so one notch moves a few lines rather than one.
            _log_scroll = max(0, min(_log_scroll + event.y * 3, max_scroll))
        elif event.type == pygame.MOUSEBUTTONDOWN:
            if event.button == 1:  # left click only; buttons 4/5 are legacy scroll wheel
                _log_scroll = 0
        elif event.type == pygame.KEYDOWN:
            if event.key == pygame.K_UP:
                _log_scroll = min(_log_scroll + 1, max_scroll)
            elif event.key == pygame.K_DOWN:
                _log_scroll = max(_log_scroll - 1, 0)
            elif event.key == pygame.K_PAGEUP:
                _log_scroll = min(_log_scroll + max_lines, max_scroll)
            elif event.key == pygame.K_PAGEDOWN:
                _log_scroll = max(_log_scroll - max_lines, 0)
            elif event.key == pygame.K_HOME:
                _log_scroll = max_scroll
            elif event.key == pygame.K_END:
                _log_scroll = 0

    if _restart_flag.is_set():
        _pg_screen.fill((255, 255, 255))
        pygame.display.flip()
        time.sleep(0.05)
        os.execv(sys.executable, [sys.executable] + sys.argv)

    return True


def _live_event_loop(scheduler_thread):
    """Main pygame event loop — runs in the main thread while the scheduler runs in its own.

    Blits the latest frame from _current_frame, redraws the status panel, and
    processes input at ~10 fps. Exits when the scheduler thread finishes or the
    window is closed.
    """
    import pygame

    pg_clock = pygame.time.Clock()
    try:
        while scheduler_thread.is_alive():
            pg_clock.tick(10)
            if not _live_pump():
                break
            if _current_frame[0] is not None:
                _live_blit_matrix(_current_frame[0])
            _live_draw_panel()
            pygame.display.flip()
    except KeyboardInterrupt:
        print("\n[sim] interrupted")


# ---------------------------------------------------------------------------
# Entry point.
# ---------------------------------------------------------------------------
class _SimStop(Exception):
    """Raised by the patched Clock.wait to exit the scheduler loop cleanly."""


def main():
    args = _build_parser().parse_args()
    output = args.output
    scale = args.scale

    # --- Trace directory setup (before config output so it prints first) ---
    if args.trace is not None:
        if args.tmpdir:
            trace_dir = tempfile.mkdtemp(prefix="weatherpanel-")
            print(f"[sim] trace directory: {trace_dir}")
        elif args.trace is True:
            _build_parser().error("--trace requires a DIR argument or --tmpdir")
        else:
            trace_dir = args.trace
            os.makedirs(trace_dir, exist_ok=True)
            print(f"[sim] trace directory: {trace_dir}")
    else:
        if args.tmpdir:
            _build_parser().error("--tmpdir requires --trace")
        trace_dir = None

    # --- Live window init (before config dump so startup messages appear in log) ---
    if args.live:
        matrix_w = 64 * scale
        matrix_h = 32 * scale
        _live_init(matrix_w, matrix_h)

    config = _load_config(args.settings)

    # --- Duration deadline ------------------------------------------------
    _start = time.monotonic()

    def _deadline_check():
        if args.duration and time.monotonic() - _start >= args.duration:
            raise _SimStop(f"--duration: {args.duration}s elapsed")

    # --- --until-ready: detect first complete forecast render -------------
    _ready = [False]
    if args.until_ready:
        import display as _display_mod
        _orig_uhf = _display_mod.Display.update_hourly_forecast
        def _patched_uhf(self, hourly_data, historical_data, current_time):
            n = _orig_uhf(self, hourly_data, historical_data, current_time)
            if n and all(s is not None for s in historical_data):
                _ready[0] = True
            return n
        _display_mod.Display.update_hourly_forecast = _patched_uhf

    # --- Capture runtime objects for state snapshots ----------------------
    # Wrap the four main constructors so we can reference the live instances
    # from _refresh_and_save without threading through scheduler internals.
    _rt = {'station': None, 'clock': None, 'display': None, 'led': None}

    import display as _display_mod
    import clock as _clock_mod
    import station as _station_mod

    _orig_Display = _display_mod.Display
    _orig_Clock = _clock_mod.Clock
    _orig_Station = _station_mod.Station

    class _TrackDisplay(_orig_Display):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['display'] = self

    class _TrackClock(_orig_Clock):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['clock'] = self

    class _TrackStation(_orig_Station):
        def __init__(self, cfg):
            super().__init__(cfg)
            _rt['station'] = self

    _display_mod.Display = _TrackDisplay
    _clock_mod.Clock = _TrackClock
    _station_mod.Station = _TrackStation

    # StatusLED: the sim module already exposes statusled_sim.color at
    # module level; the instance is accessible via statusled_sim.StatusLED.
    _orig_LED = statusled_sim.StatusLED
    class _TrackLED(_orig_LED):
        def __init__(self):
            super().__init__()
            _rt['led'] = self
    statusled_sim.StatusLED = _TrackLED

    from state_snapshot import make_png_info, snapshot_state

    # --- PNG/live refresh hook --------------------------------------------
    _orig_refresh = matrix_sim.SimDisplay.refresh
    _last_pixels = [None]
    _frame_counter = [None, -1]  # [last_sec_key, count_within_that_second]

    def _refresh_and_save(self):
        _orig_refresh(self)
        pixels = self.render_to_pixels()
        if pixels == _last_pixels[0]:
            _deadline_check()
            return
        _last_pixels[0] = [row[:] for row in pixels]
        img = (self.render_to_image(scale=scale) if args.flat
               else self.render_to_realistic_image(cell_size=scale))

        if args.live:
            _current_frame[0] = img  # main thread blits this at its own tick rate

        state = snapshot_state(
            station=_rt['station'],
            clock=_rt['clock'],
            display=_rt['display'],
            led=_rt['led'],
        )
        pnginfo = make_png_info(state) if state else None

        if trace_dir:
            now = datetime.now()
            sec_key = now.strftime("%y%m%d-%H%M%S")
            if sec_key != _frame_counter[0]:
                _frame_counter[0] = sec_key
                _frame_counter[1] = 0
            else:
                _frame_counter[1] += 1
            fname = f"{sec_key}-{_frame_counter[1]:02d}.png"
            img.save(os.path.join(trace_dir, fname), pnginfo=pnginfo)
            print(f"[sim] frame {fname}")
        elif not args.live:
            img.save(output, pnginfo=pnginfo)
            print(f"[sim] wrote {output}")

        _deadline_check()
        if args.until_ready and _ready[0]:
            raise _SimStop("--until-ready: first complete render done")

    matrix_sim.SimDisplay.refresh = _refresh_and_save

    # --- Clock.wait patch -------------------------------------------------
    import clock as _clock_module

    if args.once:
        def _wait(self):
            raise _SimStop("--once: first cycle complete")
    elif args.fast:
        def _wait(self):
            _deadline_check()
            time.sleep(5)
    else:
        _orig_wait = _clock_module.Clock.wait
        def _wait(self):
            _deadline_check()
            _orig_wait(self)
    _clock_module.Clock.wait = _wait

    # Install the SIGALRM-based watchdog only in headless mode. In --live mode
    # the scheduler runs in a daemon thread and SIGALRM fires in the main
    # thread (pygame event loop), not in the scheduler — so skip it.
    if not args.live:
        install_sim_watchdog()

    import scheduler

    if args.live:
        # Run the scheduler in a daemon thread so Clock.wait() can block
        # precisely on the minute boundary without interrupting the pygame loop.
        _sched_exc = [None]

        def _run_scheduler():
            try:
                scheduler.run(config)
            except _SimStop as e:
                _sched_exc[0] = e
            except KeyboardInterrupt:
                pass
            except Exception as e:
                _sched_exc[0] = e

        sched_thread = threading.Thread(target=_run_scheduler, daemon=True, name="scheduler")
        sched_thread.start()

        try:
            _live_event_loop(sched_thread)
        finally:
            if trace_dir:
                print(f"[sim] trace directory: {trace_dir}")
            import pygame
            pygame.quit()

        if _sched_exc[0] is not None:
            exc = _sched_exc[0]
            if isinstance(exc, _SimStop):
                print(f"[sim] {exc}")
            else:
                raise exc
    else:
        try:
            scheduler.run(config)
        except _SimStop as e:
            print(f"[sim] {e}")
        except KeyboardInterrupt:
            print("\n[sim] interrupted")
        finally:
            if trace_dir:
                print(f"[sim] trace directory: {trace_dir}")


if __name__ == "__main__":
    main()
