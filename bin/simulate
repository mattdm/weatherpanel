# ---------------------------------------------------------------------------
# Utility: discover the machine's outward-facing LAN IP address.
# ---------------------------------------------------------------------------

def _get_lan_ip():
    """Return the machine's LAN IP — the address a phone on the same network
    would use to reach this machine.

    Uses a UDP connect trick: no packet is sent, but the OS picks the
    interface that would be used to reach 8.8.8.8, revealing the LAN IP.
    Falls back to 127.0.0.1 if networking is unavailable.
    """
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        return s.getsockname()[0]
    except Exception:
        return "127.0.0.1"
    finally:
        s.close()


# ---------------------------------------------------------------------------
# Network: real src/network.py backed by adafruit_requests in CPython mode.
#
# setup_hardware() leaves adafruit_connection_manager and adafruit_requests as
# MagicMocks.  We replace them here with CPython-compatible implementations so
# network.py can create a real HTTP session.  The test suite keeps its
# MagicMocks — it never reaches this code.
# ---------------------------------------------------------------------------
import ssl as _ssl_mod
import socket as _socket_mod

# adafruit_connection_manager: use the real pip-installed library but override
# the two radio-specific helpers that don't work with a MagicMock radio.
# get_connection_manager stays real so adafruit_requests.Session gets a proper
# socket manager; only get_radio_socketpool / get_radio_ssl_context (called by
# network.py) are swapped for CPython equivalents.
sys.modules.pop("adafruit_connection_manager")
import adafruit_connection_manager as _acm_real  # noqa: E402
_acm_real.get_radio_socketpool  = lambda radio: _socket_mod
_acm_real.get_radio_ssl_context = lambda radio: _ssl_mod.create_default_context()

# adafruit_requests: real CPython-compatible library.  Pop the MagicMock first
# so the normal importer finds the installed .py (lib/*.mpy is silently skipped
# by CPython's FileFinder since .mpy is not a recognised suffix).
sys.modules.pop("adafruit_requests")
import adafruit_requests  # noqa: E402


class _FakeNTP:
    """Stand-in NTP client that returns the host machine's local time."""
    @property
    def datetime(self):
        return time.localtime()


# adafruit_ntp: still mocked (no real NTP calls), but NTP() must return
# something with a .datetime property so clock.py can read the time.
sys.modules["adafruit_ntp"].NTP = lambda pool, **kwargs: _FakeNTP()

# wifi.radio: set up the hardware-facing functions that network.py calls.
# network.ap_ip(), start_ap(), stop_ap(), and scan_networks() all delegate
# directly to wifi.radio; the scheduler's connect/check path is configured
# per-run in _run_scheduler_main below.
_wifi = sys.modules["wifi"]


class _FakeNetworkEntry:
    """Minimal stand-in for a CircuitPython wifi.Network scan entry."""
    def __init__(self, ssid, rssi):
        self.ssid = ssid
        self.rssi = rssi


_wifi.radio.start_scanning_networks = lambda: iter([
    _FakeNetworkEntry("SimNetwork-5G", -42),
    _FakeNetworkEntry("SimNetwork",    -55),
    _FakeNetworkEntry("Neighbor",      -71),
])
_wifi.radio.stop_scanning_networks  = lambda: None
_wifi.radio.start_ap  = lambda ssid, password=None: print(f"[sim] AP: {ssid}")
_wifi.radio.stop_ap   = lambda: None
# ipv4_address_ap default — overridden in _run_portal to include the HTTP port.
_wifi.radio.ipv4_address_ap = _get_lan_ip()
# Start with no AP client connected — explicit 0 so the toggle logic
# works correctly on first click (MagicMock default is truthy, which
# inverts the first click direction).
_wifi.radio.stations_ap = 0


# ---------------------------------------------------------------------------
# Parse arguments and load settings.toml.
# ---------------------------------------------------------------------------
def _build_parser():
    p = argparse.ArgumentParser(
        description="Run the weatherpanel scheduler and write display.png on each refresh."
    )
    p.add_argument("settings", metavar="settings.toml",
                   help="Path to a settings.toml (same file used on the device)")
    p.add_argument("--output", default="display.png", metavar="PATH",
                   help="Output PNG path (default: display.png); ignored with --trace or --tmpdir")
    p.add_argument("--scale", type=int, default=20, metavar="N",
                   help="Cell size in screen pixels per LED (default: 20 → 1280×640)")
    p.add_argument("--flat", action="store_true",
                   help="Use flat block pixels instead of the realistic LED dot renderer")
    p.add_argument("--no-vivid", action="store_true", dest="no_vivid",
                   help="Disable LED color boost (default: on — saturates colors to match real panels)")
    p.add_argument("--fast", action="store_true",
                   help="Replace the minute wait with a 5-second sleep")
    p.add_argument("--live", action="store_true",
                   help="Open a Wayland/SDL2 window and restart automatically on source changes")
    p.add_argument("--once", action="store_true",
                   help="Exit cleanly after the first display refresh cycle")
    p.add_argument("--trace", nargs="?", const=True, metavar="DIR",
                   help="Write each distinct frame as a timestamped PNG; "
                        "optionally specify DIR (use with --tmpdir if no DIR given)")
    p.add_argument("--tmpdir", action="store_true",
                   help="Auto-create a temp directory for --trace output and print its path")
    p.add_argument("--duration", type=float, metavar="N",
                   help="Exit after N seconds")
    p.add_argument("--until-ready", action="store_true", dest="until_ready",
                   help="Exit after the first full render (hourly + all historical data present)")
    p.add_argument("--portal", action="store_true",
                   help="Run the configuration portal instead of the weather scheduler")
    p.add_argument("--port", type=int, default=None, metavar="N",
                   help="Port for the portal HTTP server (default: 8080, "
                        "auto-increments if taken; explicit value fails if port is in use)")
    p.add_argument("--portal-save", action="store_true", dest="portal_save",
                   help="Write merged settings back to the settings.toml file after form "
                        "submission (default: print only, no file written). The file named "
                        "on the command line is the one that gets written; pass a "
                        "nonexistent path to bootstrap a fresh settings file.")
    p.add_argument("--wifi-delay", type=float, default=2.0, metavar="N", dest="wifi_delay",
                   help="Seconds to sleep in the simulated Wi-Fi connect call (default: 2.0)")
    p.add_argument("--broken-wifi", action="store_true", dest="broken_wifi",
                   help="Simulate a Wi-Fi network that never connects")
    p.add_argument("--fake-usb", action="store_true", dest="fake_usb",
                   help="Simulate a USB cable connected (shows the USB warning screen in portal mode)")
    p.add_argument("--_worker", action="store_true", dest="_worker",
                   help=argparse.SUPPRESS)  # internal: run as headless worker subprocess
    return p


def _load_config(settings_path):
    """Build the config dict from defaults and a settings.toml.

    Defaults, key sets, and coercion logic come from appconfig so they stay
    in sync with code.py automatically."""
    from appconfig import DEFAULTS, BOOL_KEYS, INT_KEYS, SECRETS, coerce_config

    config = dict(DEFAULTS)

    try:
        with open(settings_path, "rb") as f:
            toml_values = tomllib.load(f)
    except FileNotFoundError:
        print(f"[sim] {settings_path}: not found — using all defaults")
        toml_values = {}

    for key in config:
        if key in toml_values:
            config[key] = toml_values[key]
            if key in SECRETS:
                print(f"{key} = '****'")
            else:
                print(f"{key} = '{config[key]}'")
        else:
            print(f"{key} = '{config[key]}' (default)")

    config, errors = coerce_config(config, BOOL_KEYS, INT_KEYS)
    for key, msg in errors.items():
        print(f"[sim] Config error: {msg}")

    return config


