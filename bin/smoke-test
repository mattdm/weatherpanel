#!/usr/bin/env -S echo "This script runs on the CircuitPython device, not on a desktop."
"""Smoke test for watchdog-recovery stale-socket fix.

Flash this to the device as code.py (or rename/copy it), watch the serial
console, then restore the real code.py when done.

What it does
------------
1. Connects to Wi-Fi using the same settings.toml the main code uses.
2. Arms the watchdog in RAISE mode with a short timeout (WATCHDOG_TIMEOUT_S).
3. Loops network.get() to the NWS API forever — no feeding between calls.
4. The watchdog fires mid-request after WATCHDOG_TIMEOUT_S seconds.
5. The except block calls network._reset_session() and restarts the loop.
6. The very next get() goes to the same host — this is the moment under test.

Expected output with the fix
-----------------------------
  ... repeated cycling ...
  GET https://api.weather.gov/points/... OK (N.Ns to headers)
  ...
  Watchdog timeout — resetting session
  GET https://api.weather.gov/points/... OK (N.Ns to headers)
  ...

Expected output WITHOUT the fix (proves the bug exists)
--------------------------------------------------------
  GET https://api.weather.gov/points/...
  Watchdog timeout — resetting session
  GET https://api.weather.gov/points/... Transport error: RuntimeError: An existing
  socket is already connected to https://api.weather.gov:443

  Traceback (most recent call last):
    ...
  Code done running.

Usage
-----
  cp bin/smoke-test /media/<device>/code.py
  # watch serial output for 2–3 minutes
  cp code.py /media/<device>/code.py
"""
import gc
from os import getenv
import time
import wifi
import microcontroller
from watchdog import WatchDogMode, WatchDogTimeout

import network

# ---------------------------------------------------------------------------
# Config — same keys as the main code
# ---------------------------------------------------------------------------

SSID     = getenv('CIRCUITPY_WIFI_SSID')
PASSWORD = getenv('CIRCUITPY_WIFI_PASSWORD')
UA       = getenv('USER_AGENT') or "weatherpanel-smoketest"

# Short enough that the watchdog fires well within a single HTTP round-trip
# to the NWS API (which typically takes 2–8 s on the first connection).
WATCHDOG_TIMEOUT_S = 10

# Any NWS endpoint that always resolves to api.weather.gov:443 is fine.
TEST_URL = "https://api.weather.gov/points/42.36,-71.06"

# ---------------------------------------------------------------------------
# Connect
# ---------------------------------------------------------------------------

network.user_agent = UA

print("Smoke test: watchdog-recovery stale-socket")
print(f"Connecting to {SSID}...")
wifi.radio.connect(SSID, PASSWORD)
print(f"Connected. IP: {wifi.radio.ipv4_address}")

# ---------------------------------------------------------------------------
# Main loop
# ---------------------------------------------------------------------------

watchdog = microcontroller.watchdog
watchdog.timeout = WATCHDOG_TIMEOUT_S

iteration = 0
while True:
    iteration += 1
    watchdog.mode = WatchDogMode.RAISE
    # Deliberately do NOT feed the watchdog — the timeout must fire mid-GET.

    try:
        print(f"\n--- iteration {iteration} ---")
        gc.collect()
        while True:
            result = network.get(TEST_URL)
            print(f"  got result: {result is not None}")
            # No watchdog.feed() — loop until the watchdog fires.

    except WatchDogTimeout:
        print(f"Watchdog timeout after {WATCHDOG_TIMEOUT_S}s — resetting session")
        network._reset_session()
        # Falls through to the top of the outer while True, starting a new
        # iteration. The next network.get() goes to the same host immediately.
        # With the fix this succeeds; without it RuntimeError propagates out
        # of network.get() (since it was not caught before this patch) and
        # the device crashes or reloads.
